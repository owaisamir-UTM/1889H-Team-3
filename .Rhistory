decimals = 4
) %>%
tab_header(
title = "Validation Performance of LSTM Models"
) %>%
cols_align(
align = "center",
columns = everything()
) %>%
tab_style(
style = cell_text(weight = "bold"),
locations = cells_column_labels(everything())
)
